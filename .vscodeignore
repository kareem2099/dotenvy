# 1. Prevent source and development files (we only upload Javascript)
src/**
tsconfig.json
tsconfig.tsbuildinfo
.eslintrc.json
vsc-extension-quickstart.md
node_modules/**
package-lock.json
.yarnrc
yarn.lock
.vscode/**
!.vscode/extensions.json

# 2. Prevent metadata and todo list files (internal work)
todo_list*.json
*.md
!README.md
!CHANGELOG.md
!LICENSE
roadmap*.json

# 3. Security: prevent any environment files absolutely 🚫
**/.env
**/.env.*
!.env.example
.dotenvy.json
.dotenvyGit.json

# 4. Prevent source map files (for size and security)
out/**/*.js.map
test/**/*.js.map

# 5. Prevent scripts and deployment tools
scripts/**
deploy/**
infrastructure/**
k8s/**
ci-cd/**
.github/**

# 6. Prevent Python LLM project files (not the right place)
python-llm/**
llm-service/**
**/__pycache__/**
**/*.pyc
requirements.txt
Dockerfile
docker-compose.yml
railway.json

# 7. System files and IDE junk
.DS_Store
Thumbs.db
*.log
.idea/**
.git/**
.vscode-test/**
coverage/**
.nyc_output/**

# 8. Clean up resources
resources/icons/compressed.zip
resources/icons/icon.orig.png
resources/icons/compressed/**

# 9. Important exceptions (these files must be uploaded for the extension to work) ✅
!out/extension.js
!out/git-hook.js
!out/utils/*.js
!out/commands/*.js
!out/providers/*.js
!out/types/*.js
!out/managers/*.js
!resources/**

# 10. Prevent any test files (we don't need to upload tests to the marketplace)
test/**
**/test/**

# 11. Prevent any original or compressed icons (we only upload the final icons)
!resources/**

resources/icons/*.orig.*
resources/icons/*.zip
resources/icons/compressed/**

# 12. Prevent any dotenvy source files (we only upload the compiled version)
.dotenvy/**
.gitignore
.dotenvy/history