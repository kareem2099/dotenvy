{
  "name": "dotenvy",
  "displayName": "DotEnvy – VS Code Environment Manager",
  "description": "Effortlessly manage, secure, and sync .env files directly inside VS Code with enterprise-grade encryption.",
  "version": "2.0.1",
  "icon": "resources/icons/icon.png",
  "publisher": "FreeRave",
  "author": "Kareem Ehab",
  "license": "Apache-2.0",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "keywords": [
    "Productivity",
    "env",
    "environment",
    "dotenv",
    "security",
    "encryption",
    "sync",
    "secrets"
  ],
  "activationEvents": [
    "onStartupFinished",
    "workspaceContains:**/.env",
    "workspaceContains:**/.env.*"
  ],
  "main": "./out/extension.js",
  "bin": {
    "dotenvy-hook": "./out/git-hook.js"
  },
  "scripts": {
    "vscode:prepublish": "npm run compile && npm run substitute-env",
    "compile": "tsc -p ./",
    "substitute-env": "node scripts/build-with-env.js",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run substitute-env && npm run lint",
    "lint": "eslint src/**/*.ts",
    "test": "node ./out/test/runTest.js"
  },
  "contributes": {
    "languages": [
      {
        "id": "dotenvyignore",
        "filenames": [
          ".dotenvyignore"
        ],
        "icon": {
          "light": "./resources/icons/dotenvyignoreIcon.svg",
          "dark": "./resources/icons/dotenvyignoreIcon.svg"
        }
      }
    ],
    "configuration": {
      "title": "DotEnvy",
      "properties": {
        "dotenvy.backupPath": {
          "type": "string",
          "default": "",
          "description": "Path to store encrypted backups of .env files. Leave empty to use workspace folder."
        },
        "dotenvy.encryptBackups": {
          "type": "boolean",
          "default": true,
          "description": "Enable AES-256 encryption for backup files."
        },
        "dotenvy.history.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable environment history tracking."
        },
        "dotenvy.history.retentionDays": {
          "type": "number",
          "default": 180,
          "minimum": 1,
          "maximum": 3650,
          "description": "Number of days to retain environment history."
        },
        "dotenvy.history.maxEntries": {
          "type": "number",
          "default": 1000,
          "minimum": 10,
          "maximum": 10000,
          "description": "Maximum number of history entries to keep."
        },
        "dotenvy.history.autoCleanup": {
          "type": "boolean",
          "default": true,
          "description": "Automatically clean up old history entries."
        },
        "dotenvy.cloudSync.encryptCloudSync": {
          "type": "boolean",
          "default": true,
          "description": "Encrypt secrets before syncing to cloud (End-to-End Encryption)."
        },
        "dotenvy.cloudSync.provider": {
          "type": "string",
          "default": "doppler",
          "enum": [
            "doppler",
            "vercel",
            "aws"
          ],
          "description": "Cloud provider to sync secrets with."
        }
      }
    },
    "commands": [
      {
        "command": "dotenvy.scanSecrets",
        "title": "DotEnvy: Scan for Secrets",
        "icon": "$(search-view-icon)"
      },
      {
        "command": "dotenvy.switchEnvironment",
        "title": "DotEnvy: Switch Environment"
      },
      {
        "command": "dotenvy.initDotenvyIgnore",
        "title": "DotEnvy: Init .dotenvyignore",
        "icon": "$(exclude)"
      },
      {
        "command": "dotenvy.addToIgnore",
        "title": "DotEnvy: Ignore this path",
        "icon": "$(eye-closed)"
      },
      {
        "command": "dotenvy.openEnvironmentPanel",
        "title": "DotEnvy: Open Main Dashboard"
      },
      {
        "command": "dotenvy.openVariableManager",
        "title": "DotEnvy: Open Variable Manager",
        "icon": "$(edit)"
      },
      {
        "command": "dotenvy.setupLLMSecret",
        "title": "DotEnvy: Setup LLM Secret",
        "icon": "$(key)"
      },
      {
        "command": "dotenvy.validateEnvironment",
        "title": "DotEnvy: Validate Environment Files"
      },
      {
        "command": "dotenvy.diffEnvironment",
        "title": "DotEnvy: Diff Environment Files"
      },
      {
        "command": "dotenvy.installGitHook",
        "title": "DotEnvy: Install Git Commit Hook"
      },
      {
        "command": "dotenvy.removeGitHook",
        "title": "DotEnvy: Remove Git Commit Hook"
      },
      {
        "command": "dotenvy.pullFromCloud",
        "title": "DotEnvy: Pull Environment from Cloud"
      },
      {
        "command": "dotenvy.pushToCloud",
        "title": "DotEnvy: Push Environment to Cloud"
      },
      {
        "command": "dotenvy.feedback",
        "title": "DotEnvy: Feedback & Support"
      },
      {
        "command": "dotenvy.viewEnvironmentHistory",
        "title": "DotEnvy: View Environment History"
      },
      {
        "command": "dotenvy.openHistoryPanel",
        "title": "DotEnvy: Open History Panel",
        "icon": "$(history)"
      },
      {
        "command": "dotenvy.openAnalyticsPanel",
        "title": "DotEnvy: Open Analytics Panel",
        "icon": "$(graph)"
      },
      {
        "command": "dotenvy.openTimelinePanel",
        "title": "DotEnvy: Open Timeline Panel",
        "icon": "$(history)"
      },
      {
        "command": "dotenvy.initSecureProject",
        "title": "DotEnvy: Init Secure Project",
        "icon": "$(shield-lock)"
      },
      {
        "command": "dotenvy.addUser",
        "title": "DotEnvy: Add User to Secure Project",
        "icon": "$(person-add)"
      },
      {
        "command": "dotenvy.revokeUser",
        "title": "DotEnvy: Revoke User Access",
        "icon": "$(person-remove)"
      },
      {
        "command": "dotenvy.loginToSecureProject",
        "title": "DotEnvy: Login to Secure Project",
        "icon": "$(unlock)"
      },
      {
        "command": "dotenvy.showChangelog",
        "title": "DotEnvy: Show What's New",
        "category": "DotEnvy"
      },
      {
        "command": "dotenvy.backup",
        "title": "DotEnvy: Backup Current Environment",
        "icon": "$(archive)"
      },
      {
        "command": "dotenvy.restore",
        "title": "DotEnvy: Restore from Backup",
        "icon": "$(history)"
      },
      {
        "command": "dotenvy.openTrashBin",
        "title": "DotEnvy: Open Session Trash Bin",
        "icon": "$(trash)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "dotenvy",
          "title": "DotEnvy",
          "icon": "./resources/icons/icon.png"
        }
      ]
    },
    "views": {
      "dotenvy": [
        {
          "id": "dotenvy.environments",
          "name": "Environment Switcher",
          "type": "webview",
          "icon": "$(settings-gear)"
        },
        {
          "id": "dotenvy.commands",
          "name": "Secure Commands",
          "type": "tree",
          "icon": "$(lock)"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "dotenvy.openVariableManager",
          "when": "view == dotenvy.environments",
          "group": "navigation@0"
        },
        {
          "command": "dotenvy.openHistoryPanel",
          "when": "view == dotenvy.environments",
          "group": "navigation@1"
        },
        {
          "command": "dotenvy.openAnalyticsPanel",
          "when": "view == dotenvy.environments",
          "group": "navigation@2"
        }
      ],
      "explorer/context": [
        {
          "command": "dotenvy.addToIgnore",
          "group": "navigation@2"
        }
      ]
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/kareem2099/dotenvy"
  },
  "homepage": "https://github.com/kareem2099/dotenvy",
  "bugs": {
    "url": "https://github.com/kareem2099/dotenvy/issues"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/mocha": "^10.0.10",
    "@types/node": "^25.6.0",
    "@types/vscode": "^1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "@vscode/test-electron": "^2.3.0",
    "dotenv": "^17.3.1",
    "eslint": "^10.2.0",
    "glob": "^13.0.6",
    "globals": "^17.4.0",
    "mocha": "^11.3.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1"
  },
  "dependencies": {
    "uuid": "^13.0.0"
  }
}