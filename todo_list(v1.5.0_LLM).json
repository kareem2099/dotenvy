        },
        {
          "id": "hmac_extension",
          "title": "HMAC Signing — Extension Side",
          "status": "completed",
          "file": "DotEnvy/src/utils/llmAnalyzer.ts",
          "features": [
            "signRequest() — HMAC-SHA256 with Unix timestamp",
            "makeSignedRequest() — injects X-Extension-Timestamp + X-Extension-Signature + X-Machine-ID",
            "No API key in extension — shared secret only",
            "Circuit breaker (3 failures → open, 60s cooldown)"
          ]
        },
        {
          "id": "hmac_build",
          "title": "Build Script — Secret Injection",
          "status": "completed",
          "file": "DotEnvy/scripts/build-with-env.js",
